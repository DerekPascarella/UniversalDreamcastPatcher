<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UniversalDreamcastPatcher.App.Views.ManualUpdateDialog"
        Title="Manual Update Required" SizeToContent="Height" Width="470"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="avares://UniversalDreamcastPatcher/Assets/sega_dreamcast.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="ReasonText" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Text="To upgrade, download the release package from the GitHub repository:"/>

            <TextBlock Foreground="#1E88E5" TextDecorations="Underline" Cursor="Hand"
                       ToolTip.Tip="Open the releases page in your browser"
                       PointerPressed="ReleasesLink_PointerPressed"
                       Text="https://github.com/DerekPascarella/UniversalDreamcastPatcher/releases"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Skip This Version" Click="SkipButton_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="0,0,5,0"/>
            <Button Grid.Column="1" Content="OK" Click="OkButton_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</Window>
