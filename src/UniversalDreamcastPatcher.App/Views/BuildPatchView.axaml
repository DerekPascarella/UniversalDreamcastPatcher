<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniversalDreamcastPatcher.App.Views.BuildPatchView">

    <StackPanel Margin="12" Spacing="12">

        <!-- Original GDI -->
        <StackPanel Spacing="4">
            <TextBlock Text="Original disc image" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" x:Name="OriginalGdiPath" Watermark="Select the unpatched .gdi, .cue, or .chd..." IsReadOnly="True" />
                <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0" MinWidth="90" x:Name="BrowseOriginalGdi"
                        ToolTip.Tip="Choose the unpatched (original) disc image (.gdi, .cue, or .chd)" />
            </Grid>
        </StackPanel>

        <!-- Modified GDI -->
        <StackPanel Spacing="4">
            <TextBlock Text="Modified disc image" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" x:Name="ModifiedGdiPath" Watermark="Select the modified .gdi, .cue, or .chd..." IsReadOnly="True" />
                <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0" MinWidth="90" x:Name="BrowseModifiedGdi"
                        ToolTip.Tip="Choose the patched (modified) disc image (.gdi, .cue, or .chd)" />
            </Grid>
        </StackPanel>

        <!-- Output file -->
        <StackPanel Spacing="4">
            <TextBlock Text="Output DCP patch file" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" x:Name="OutputDcpPath" Watermark="Choose where to save the .dcp..." IsReadOnly="True" />
                <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0" MinWidth="90" x:Name="BrowseBuildOutputFile"
                        ToolTip.Tip="Choose where the .dcp patch file will be saved" />
            </Grid>
        </StackPanel>

        <!-- IP.BIN options -->
        <StackPanel Spacing="6">
            <CheckBox x:Name="UseCustomIpBin"
                      Content="Customize IP.BIN"
                      FontWeight="SemiBold"
                      ToolTip.Tip="Bundle a custom IP.BIN inside the patch instead of leaving the source's IP.BIN untouched" />

            <StackPanel Margin="20,0,0,0" Spacing="10" IsEnabled="{Binding #UseCustomIpBin.IsChecked}">
                <StackPanel.Styles>
                    <Style Selector="TextBlock:disabled">
                        <Setter Property="Foreground" Value="#888" />
                    </Style>
                </StackPanel.Styles>

                <StackPanel Spacing="4">
                    <TextBlock Text="IP.BIN source" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <RadioButton x:Name="IpBinFromModified" Content="Modified disc image" GroupName="IpBinSource" IsChecked="True"
                                     ToolTip.Tip="Take the bundled IP.BIN from the modified disc image" />
                        <RadioButton x:Name="IpBinFromOriginal" Content="Original disc image" GroupName="IpBinSource"
                                     ToolTip.Tip="Take the bundled IP.BIN from the original disc image" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Modifications" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <CheckBox x:Name="IpBinRegionFree" Content="Region-free"
                                  ToolTip.Tip="Make the disc boot on any region (Japan, USA, Europe)" />
                        <CheckBox x:Name="IpBinVga" Content="Enable VGA"
                                  ToolTip.Tip="Mark the disc as supporting 480p VGA output" />
                        <CheckBox x:Name="UseCustomGameName" Content="Use custom game name"
                                  ToolTip.Tip="Replace the game name stored in IP.BIN with a custom value (up to 128 ASCII characters)" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Custom game name" FontWeight="SemiBold" />
                    <TextBox x:Name="CustomGameName"
                             Watermark="MY GAME NAME (ENGLISH)"
                             MaxLength="128"
                             IsEnabled="{Binding #UseCustomGameName.IsChecked}"
                             ToolTip.Tip="Custom game name written into IP.BIN. Uppercase ASCII, up to 128 characters" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Action area -->
        <Grid x:Name="BuildActionArea" MinHeight="60" Margin="0,4,0,0">

            <Button x:Name="BuildPatchButton"
                    Content="Build Patch"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    IsEnabled="False"
                    ToolTip.Tip="Diff the original against the modified disc image and write the .dcp" />

            <StackPanel x:Name="BuildBusyPanel"
                        IsVisible="False"
                        VerticalAlignment="Center"
                        Spacing="6">
                <ProgressBar IsIndeterminate="True"
                             Height="16" />
                <TextBlock x:Name="BuildProgressLabel"
                           HorizontalAlignment="Center"
                           Foreground="#333"
                           Text="" />
            </StackPanel>

        </Grid>

    </StackPanel>

</UserControl>
