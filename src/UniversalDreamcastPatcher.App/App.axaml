<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniversalDreamcastPatcher.App.App"
             Name="Universal Dreamcast Patcher"
             RequestedThemeVariant="Light">

    <!-- Override Avalonia's hardcoded "About Avalonia" entry in the macOS app menu.
         Defining a NativeMenu here suppresses CreateDefaultAppMenu(); the standard
         Services/Hide/Quit items are still appended automatically. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Universal Dreamcast Patcher" Click="AboutMenuItem_Click"/>
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Resources>
        <!-- Brand navy. Light/Dark variants are HSL L +/- 10/20/30 from base. -->
        <Color x:Key="SystemAccentColor">#254d8a</Color>
        <Color x:Key="SystemAccentColorLight1">#2f63b1</Color>
        <Color x:Key="SystemAccentColorLight2">#467cce</Color>
        <Color x:Key="SystemAccentColorLight3">#6e99d8</Color>
        <Color x:Key="SystemAccentColorDark1">#1a3661</Color>
        <Color x:Key="SystemAccentColorDark2">#0f2038</Color>
        <Color x:Key="SystemAccentColorDark3">#091220</Color>

        <Color x:Key="TextControlSelectionHighlightColor">#CCCCCC</Color>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Default all buttons to centered text. -->
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- Progress fill follows the brand navy (matches the overridden accent). -->
        <Style Selector="ProgressBar">
            <Setter Property="Foreground" Value="#254d8a"/>
        </Style>

        <!-- Slow the indeterminate marquee by 25% (2s default -> 2.5s) on horizontal ProgressBars. -->
        <Style Selector="ProgressBar:horizontal:indeterminate /template/ Border#IndeterminateProgressBarIndicator">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2.5">
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:0">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:1.875">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:2.5">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="ProgressBar:horizontal:indeterminate /template/ Border#IndeterminateProgressBarIndicator2">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2.5">
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:0">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:0.9375">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeySpline="0.4,0,0.6,1" KeyTime="0:0:2.5">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>

</Application>
